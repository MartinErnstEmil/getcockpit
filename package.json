{
  "name": "getcockpit",
  "version": "0.2.0",
  "description": "The project state that writes itself: searchable archive of all your Claude Code sessions, portfolio status, standups and a persistent agent inbox. Local-first, no cloud, no embeddings.",
  "license": "PolyForm-Noncommercial-1.0.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MartinErnstEmil/getcockpit.git"
  },
  "homepage": "https://github.com/MartinErnstEmil/getcockpit",
  "type": "module",
  "bin": {
    "cockpit": "dist/cli.js",
    "cockpit-mcp": "dist/mcp.js"
  },
  "main": "dist/index.js",
  "files": [
    "dist",
    "docs/HANDBUCH.md",
    "docs/INSTALL.md",
    "docs/TESTPROTOKOLL.md",
    "snippets",
    "LICENSE",
    "LICENSE-COMMERCIAL.md",
    "NOTICE",
    "README.md"
  ],
  "engines": {
    "node": ">=22.5"
  },
  "workspaces": [
    "spa"
  ],
  "scripts": {
    "build": "tsc && node scripts/build-hooks.mjs && npm -w @getcockpit/cockpit-spa run build",
    "build:server": "tsc && node scripts/build-hooks.mjs",
    "test": "npm run build:server && vitest run",
    "typecheck": "tsc --noEmit",
    "typecheck:spa": "npm -w @getcockpit/cockpit-spa run typecheck",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "better-sqlite3": "^12.2.0",
    "@modelcontextprotocol/sdk": "^1.13.0",
    "commander": "^14.0.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.15.0",
    "esbuild": "^0.25.5",
    "typescript": "^5.8.0",
    "vitest": "^3.2.0"
  }
}
