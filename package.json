{
  "name": "getcockpit",
  "version": "0.5.0",
  "description": "The project state that writes itself: searchable archive of all your Claude Code sessions, portfolio status, standups and a persistent agent inbox. Local-first, no cloud, no embeddings.",
  "license": "PolyForm-Noncommercial-1.0.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MartinErnstEmil/getcockpit.git"
  },
  "homepage": "https://github.com/MartinErnstEmil/getcockpit",
  "type": "module",
  "bin": {
    "cockpit": "dist/cli.js",
    "cockpit-mcp": "dist/mcp.js"
  },
  "main": "dist/index.js",
  "files": [
    "dist",
    "docs/HANDBUCH.md",
    "docs/INSTALL.md",
    "docs/TESTPROTOKOLL.md",
    "snippets",
    "LICENSE",
    "LICENSE-COMMERCIAL.md",
    "NOTICE",
    "README.md"
  ],
  "engines": {
    "node": ">=22.5"
  },
  "workspaces": [
    "spa"
  ],
  "scripts": {
    "build": "tsc && node scripts/build-hooks.mjs && npm -w @getcockpit/cockpit-spa run build",
    "build:server": "tsc && node scripts/build-hooks.mjs",
    "test": "npm run build:server && vitest run",
    "typecheck": "tsc --noEmit",
    "typecheck:spa": "npm -w @getcockpit/cockpit-spa run typecheck",
    "prepublishOnly": "npm run build",
    "app:icon": "node electron/make-icon.mjs",
    "app:rebuild": "electron-rebuild --force --only better-sqlite3",
    "app:restore": "npm rebuild better-sqlite3",
    "app:dev": "npm run app:rebuild && electron electron/main.cjs",
    "app:build": "npm run build && npm run app:rebuild && electron-builder && npm run app:restore"
  },
  "build": {
    "appId": "de.extracode.cockpit",
    "productName": "Cockpit",
    "asar": false,
    "extraMetadata": {
      "main": "electron/main.cjs"
    },
    "files": [
      "electron/**",
      "dist/**",
      "package.json",
      "!**/node_modules/*/{CHANGELOG.md,README.md,README,readme.md,readme,test,__tests__,tests,powered-test,example,examples}"
    ],
    "directories": {
      "output": "release",
      "buildResources": "electron/build"
    },
    "win": {
      "target": "nsis",
      "icon": "electron/build/icon.ico"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Cockpit"
    }
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.13.0",
    "better-sqlite3": "^12.2.0",
    "commander": "^14.0.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.2.0",
    "@resvg/resvg-js": "^2.6.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.15.0",
    "electron": "^37.10.3",
    "electron-builder": "^26.15.3",
    "esbuild": "^0.25.5",
    "png-to-ico": "^3.0.2",
    "typescript": "^5.8.0",
    "vitest": "^3.2.0"
  }
}
